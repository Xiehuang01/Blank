PORT=# 应用运行端口，例如 3000
NODE_ENV=# 运行环境，可选值：development / production / test

# MySQL 数据库配置
DB_HOST=# MySQL 数据库主机地址，例如 127.0.0.1
DB_PORT=# MySQL 数据库端口，默认 3306
DB_USER=# MySQL 数据库用户名
DB_PASSWORD=# MySQL 数据库密码
DB_NAME=# MySQL 数据库名称

# Redis配置
REDIS_HOST=# Redis 主机地址，例如 127.0.0.1
REDIS_PORT=# Redis 端口，默认 6379
REDIS_PASSWORD=# Redis 密码，无密码则留空

# JWT 配置
JWT_SECRET=# JWT 签名密钥，请使用随机字符串
JWT_EXPIRE=# JWT 过期时间，例如 7d 表示 7 天

# DashScope API
DASHSCOPE_API_KEY=# 阿里云 DashScope API 密钥

# CORS 配置
CORS_ORIGIN=# 允许跨域访问的前端域名，例如 http://localhost:5173

# 邮箱配置
EMAIL_HOST=# SMTP 邮件服务器地址，例如 smtp.qq.com
EMAIL_PORT=# SMTP 邮件服务器端口，例如 465
EMAIL_SECURE=# 是否使用 SSL/TLS，true 或 false
EMAIL_USER=# SMTP 邮箱账号
EMAIL_PASSWORD=# SMTP 邮箱授权码（非邮箱登录密码）
EMAIL_FROM=# 发件人显示名称和邮箱，格式：EchoDiary <your_email@example.com>

# 邮箱验证配置
EMAIL_VERIFY_EXPIRY=# 验证码有效期，单位秒，例如 300 表示 5 分钟
VERIFICATION_CODE_LENGTH=# 验证码长度，例如 6

# 文件上传配置
UPLOAD_DIR=# 文件上传存储目录，例如 uploads
MAX_FILE_SIZE=# 单文件上传最大大小，单位字节，例如 10485760 表示 10MB

# ZPAY 易支付配置
ZPAY_BASE_URL=# 易支付网关地址，例如 https://pay.example.com
ZPAY_PID=# 易支付商户 ID
ZPAY_PKEY=# 易支付商户密钥
ZPAY_DEFAULT_TYPE=# 默认支付方式，例如 alipay / wxpay
# 可选：指定支付渠道ID，不填则由平台随机分配
ZPAY_CID=# 易支付渠道ID，可选，不填则由平台随机分配
# 可选：前端站点地址，用于支付成功后跳回 /vip
APP_BASE_URL=# 前端站点地址，例如 https://example.com
# 可选：后端公网地址，用于异步通知；留空时会根据请求自动推断
API_PUBLIC_BASE_URL=# 后端公网地址，用于支付异步回调通知，留空则自动推断
